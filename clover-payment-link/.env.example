# Copy these into Vercel → Project → Settings → Environment Variables.
# Do NOT commit real values to git.

# Private Ecommerce API token from the Clover dashboard (integration type: "Hosted checkout")
CLOVER_API_TOKEN=

# The merchant ID shown next to the token on the same Clover page
CLOVER_MERCHANT_ID=

# Optional. Leave unset for live North America payments (https://api.clover.com).
# For testing with a sandbox token, set this to https://apisandbox.dev.clover.com
# For Europe, set this to https://api.eu.clover.com
# CLOVER_BASE_URL=https://api.clover.com
